  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.7.0",
    "nodemailer": "^8.0.7",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
